<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>管理者設定 - COLOR KITCHEN</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner">
    <h1>COLOR KITCHEN 採用管理</h1>
    <nav class="header-nav">
      <a href="/admin" class="nav-link">応募者一覧</a>
      <a href="/admin/templates" class="nav-link">テンプレート</a>
      <a href="/admin/auto-replies" class="nav-link">自動返信</a>
      <a href="/admin/logout" class="logout-link">ログアウト</a>
    </nav>
  </div>
</header>
<main>
  <div class="page-header">
    <h2>管理者設定</h2>
  </div>

  <% if (msg) { %>
  <div class="alert alert-<%= msg.includes('更新') || msg.includes('追加') || msg.includes('削除') ? 'success' : 'error' %>"><%= msg %></div>
  <% } %>

  <!-- サイドナビ -->
  <div class="settings-layout">
    <aside class="settings-nav">
      <div class="settings-nav-title">設定メニュー</div>
      <a href="/admin/settings" class="settings-nav-item active">管理者アカウント</a>
      <a href="/admin/settings/line" class="settings-nav-item">LINE設定</a>
      <a href="/admin/templates" class="settings-nav-item">テンプレート管理</a>
      <a href="/admin/auto-replies" class="settings-nav-item">自動返信設定</a>
      <a href="/admin/richmenu" class="settings-nav-item">リッチメニュー</a>
    </aside>

    <div class="settings-content">

      <% if (!editAdmin) { %>
      <!-- 管理者アカウント一覧 -->
      <div class="card">
        <h3>管理者アカウント一覧</h3>
        <div class="table-wrap">
          <table>
            <thead>
              <tr>
                <th>管理者ID</th>
                <th>名前</th>
                <th>メールアドレス</th>
                <th>ロール</th>
                <th>登録日時</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td><strong><%= masterAdminId %>（マスター）</strong></td>
                <td><%= masterInfo ? masterInfo.name : '管理者' %></td>
                <td class="small-text"><%= masterInfo ? (masterInfo.email || '未設定') : '環境変数で設定' %></td>
                <td><span class="badge badge-done">master</span></td>
                <td class="small-text"><%= masterInfo ? (masterInfo.registered_at || '-') : '-' %></td>
                <td>
                  <a href="/admin/settings/edit/<%= masterAdminId %>" class="btn btn-sm">編集</a>
                </td>
              </tr>
              <% if (admins.length === 0) { %>
              <tr><td colspan="6" class="empty-row">追加アカウントなし</td></tr>
              <% } %>
              <% admins.forEach(a => { %>
              <tr>
                <td><strong><%= a.admin_id %></strong></td>
                <td><%= a.name %></td>
                <td class="small-text"><%= a.email || '-' %></td>
                <td><span class="badge badge-pending"><%= a.role || 'admin' %></span></td>
                <td class="small-text"><%= a.registered_at || '-' %></td>
                <td style="display:flex;gap:0.4rem;align-items:center">
                  <a href="/admin/settings/edit/<%= a.admin_id %>" class="btn btn-sm">編集</a>
                  <form action="/admin/settings/delete/<%= a.admin_id %>" method="POST" style="display:inline"
                    onsubmit="return confirm('<%= a.name %>（<%= a.admin_id %>）を削除しますか？')">
                    <button type="submit" class="btn-delete">削除</button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>

      <!-- アカウント追加 -->
      <div class="card">
        <h3>アカウントを追加</h3>
        <form action="/admin/settings/add" method="POST">
          <div class="grid-2">
            <div class="form-group">
              <label class="required">管理者ID</label>
              <input type="text" name="id" placeholder="例: staff01" required>
              <small>半角英数字・記号</small>
            </div>
            <div class="form-group">
              <label class="required">パスワード</label>
              <input type="text" name="password" placeholder="例: pass1234" required>
            </div>
            <div class="form-group">
              <label class="required">名前</label>
              <input type="text" name="name" placeholder="例: 山田 太郎" required>
            </div>
            <div class="form-group">
              <label>メールアドレス（通知先）</label>
              <input type="email" name="email" placeholder="例: staff@example.com">
            </div>
            <div class="form-group">
              <label>ロール</label>
              <select name="role">
                <option value="admin">admin</option>
                <option value="staff">staff</option>
              </select>
            </div>
            <div class="form-group">
              <label>担当店舗</label>
              <input type="text" name="store" placeholder="例: 三軒茶屋店">
            </div>
          </div>
          <button type="submit" class="btn-primary">追加する</button>
        </form>
      </div>

      <!-- メール通知説明 -->
      <div class="card">
        <h3>メール通知について</h3>
        <p style="font-size:0.88rem;color:#555;line-height:1.8">
          登録されたメールアドレスに以下のタイミングで通知が届きます：<br>
          ・<strong>新規友達追加</strong>時<br>
          ・<strong>アンケート記入完了</strong>時<br>
          ・<strong>入社希望 / 辞退</strong>の回答受信時<br>
          ・<strong>ブロック</strong>時<br><br>
          マスター管理者の通知先は <code>NOTIFY_EMAIL_TO</code> 環境変数でも設定できます。
        </p>
      </div>
      <% } %>

      <!-- 編集フォーム -->
      <% if (editAdmin) { %>
      <div class="card">
        <h3>アカウントを編集</h3>
        <form action="/admin/settings/edit/<%= editAdmin.admin_id || editAdmin.id %>" method="POST">
          <div class="grid-2">
            <div class="form-group">
              <label>管理者ID</label>
              <input type="text" value="<%= editAdmin.admin_id || editAdmin.id %>" readonly class="readonly-field">
              <small>IDは変更できません</small>
            </div>
            <div class="form-group">
              <label>パスワード</label>
              <input type="text" name="password" placeholder="変更しない場合は空欄">
              <small>空欄のままにすると現在のパスワードを維持</small>
            </div>
            <div class="form-group">
              <label class="required">名前</label>
              <input type="text" name="name" value="<%= editAdmin.name || '' %>" required>
            </div>
            <div class="form-group">
              <label>メールアドレス</label>
              <input type="email" name="email" value="<%= editAdmin.email || '' %>">
            </div>
          </div>
          <div style="display:flex;gap:0.75rem;margin-top:0.5rem">
            <button type="submit" class="btn-primary">保存する</button>
            <a href="/admin/settings" class="btn-secondary" style="display:inline-flex;align-items:center;text-decoration:none">キャンセル</a>
          </div>
        </form>
      </div>
      <% } %>

    </div>
  </div>
</main>
</body>
</html>
