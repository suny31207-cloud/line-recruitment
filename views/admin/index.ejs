<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>応募者一覧 - COLOR KITCHEN 採用管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner" style="display:flex;align-items:center;justify-content:space-between">
    <h1>COLOR KITCHEN 採用管理システム</h1>
    <div style="display:flex;gap:1rem;align-items:center">
      <a href="/admin/settings" class="logout-link" style="color:#aad4c8">管理者設定</a>
      <a href="/admin/logout" class="logout-link">ログアウト</a>
    </div>
  </div>
</header>
<main>
  <div class="page-header">
    <h2>応募者一覧 <span class="count-badge"><%= candidates.length %>名</span></h2>
  </div>

  <!-- フィルターバー -->
  <div class="filter-bar">
    <label>
      <input type="checkbox" id="filterNeedsReply" onchange="toggleFilter()">
      要返信のみ表示
    </label>
    <% const needsReplyCount = candidates.filter(c => c.needsReply === '要返信').length; %>
    <% if (needsReplyCount > 0) { %>
    <span class="badge-needs-reply"><%= needsReplyCount %>件 要返信</span>
    <% } %>
  </div>

  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>応募者名</th>
          <th>要返信</th>
          <th>最新問い合わせ</th>
          <th>希望内容</th>
          <th>ステータス</th>
          <th>アンケート</th>
          <th>見学予約日</th>
          <th>面接予定日</th>
          <th>回答結果</th>
          <th>最終受信日時</th>
          <th>登録日時</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (candidates.length === 0) { %>
        <tr>
          <td colspan="12" class="empty-row">応募者がいません</td>
        </tr>
        <% } %>
        <% candidates.forEach(c => { %>
        <tr class="<%= c.needsReply === '要返信' ? 'row-needs-reply' : '' %>" data-needs-reply="<%= c.needsReply === '要返信' ? '1' : '0' %>">
          <td>
            <strong><%= c.name || '(名前未登録)' %></strong>
            <% if (c.changeRequested) { %><span class="change-indicator">🔔変更希望</span><% } %>
            <div class="sub-text"><%= c.lineUserId %></div>
          </td>
          <td>
            <% if (c.needsReply === '要返信') { %>
              <span class="badge-needs-reply">要返信</span>
            <% } else if (c.needsReply === '対応済み') { %>
              <span class="badge-replied">対応済み</span>
            <% } else { %>-<% } %>
          </td>
          <td>
            <% if (c.latestInquiry) { %>
              <div class="inquiry-preview" title="<%= c.latestInquiry %>"><%= c.latestInquiry %></div>
              <div class="sub-text"><%= c.latestInquiryDate %></div>
            <% } else { %>-<% } %>
          </td>
          <td><%= c.preference || '-' %></td>
          <td>
            <span class="status-badge status-<%= c.status.replace(/\s/g,'') %>">
              <%= c.status %>
            </span>
          </td>
          <td>
            <% if (c.surveyDone) { %>
              <span class="badge badge-done">回答済み</span>
            <% } else { %>
              <span class="badge badge-pending">未回答</span>
            <% } %>
          </td>
          <td>
            <%= c.visitDate || '-' %>
            <% if (c.store) { %><div class="small-text"><%= c.store %></div><% } %>
          </td>
          <td>
            <%= c.interviewDate || '-' %>
            <% if (c.store) { %><div class="small-text"><%= c.store %></div><% } %>
          </td>
          <td>
            <% if (c.answer) { %>
              <span class="answer-badge answer-<%= c.answer === '入社希望' ? 'join' : 'decline' %>">
                <%= c.answer %>
              </span>
            <% } else { %>-<% } %>
          </td>
          <td class="small-text"><%= c.lastReceived || '-' %></td>
          <td class="small-text"><%= c.registeredAt || '-' %></td>
          <td>
            <a href="/admin/candidates/<%= c.lineUserId %>" class="btn btn-sm">詳細</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<script>
function toggleFilter() {
  const checked = document.getElementById('filterNeedsReply').checked;
  document.querySelectorAll('tbody tr[data-needs-reply]').forEach(row => {
    if (checked && row.dataset.needsReply !== '1') {
      row.style.display = 'none';
    } else {
      row.style.display = '';
    }
  });
}
</script>
</body>
</html>
