<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>応募者一覧 - COLOR KITCHEN 採用管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner">
    <h1>COLOR KITCHEN 採用管理</h1>
    <nav class="header-nav">
      <a href="/admin/templates" class="nav-link">テンプレート</a>
      <a href="/admin/auto-replies" class="nav-link">自動返信</a>
      <a href="/admin/settings" class="nav-link">設定</a>
      <a href="/admin/logout" class="logout-link">ログアウト</a>
    </nav>
  </div>
</header>
<main>
  <div class="page-header">
    <%
      const activeCount = candidates.length;
      const needsReplyCount = candidates.filter(c => c.needs_reply === '要返信').length;
    %>
    <h2>応募者一覧 <span class="count-badge"><%= activeCount %>名</span></h2>
    <% if (needsReplyCount > 0) { %>
    <span class="badge-needs-reply badge-pulse"><%= needsReplyCount %>件 要返信</span>
    <% } %>
  </div>

  <!-- フィルターバー -->
  <div class="filter-bar">
    <label>
      <input type="checkbox" id="filterNeedsReply" onchange="applyFilters()">
      要返信のみ
    </label>
    <label>
      <input type="checkbox" id="filterHideBlocked" checked onchange="applyFilters()">
      ブロック済み除外
    </label>
    <select id="filterStatus" onchange="applyFilters()" class="filter-select">
      <option value="">全ステータス</option>
      <% statuses.forEach(s => { %>
      <option value="<%= s %>"><%= s %></option>
      <% }) %>
    </select>
  </div>

  <div class="table-wrap">
    <table id="candidatesTable">
      <thead>
        <tr>
          <th>氏名</th>
          <th>要返信</th>
          <th>ステータス</th>
          <th>最寄駅</th>
          <th>希望店舗</th>
          <th>最終受信</th>
          <th>登録日</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% if (candidates.length === 0) { %>
        <tr>
          <td colspan="8" class="empty-row">応募者がいません</td>
        </tr>
        <% } %>
        <% candidates.forEach(c => { %>
        <tr
          class="<%= c.needs_reply === '要返信' ? 'row-needs-reply' : '' %> <%= c.is_blocked ? 'row-blocked' : '' %>"
          data-needs-reply="<%= c.needs_reply === '要返信' ? '1' : '0' %>"
          data-blocked="<%= c.is_blocked ? '1' : '0' %>"
          data-status="<%= c.status || '' %>"
        >
          <td>
            <strong><%= c.name || c.display_name || '(名前未登録)' %></strong>
            <div class="sub-text"><%= c.line_user_id %></div>
          </td>
          <td>
            <% if (c.needs_reply === '要返信') { %>
              <span class="badge-needs-reply">要返信</span>
            <% } else if (c.needs_reply === '対応済み') { %>
              <span class="badge-replied">対応済み</span>
            <% } else { %><span class="text-muted">-</span><% } %>
          </td>
          <td>
            <span class="status-badge status-<%= (c.status || '').replace(/\s/g,'_') %>">
              <%= c.status || '-' %>
            </span>
          </td>
          <td class="small-text"><%= c.station || '-' %></td>
          <td class="small-text"><%= c.store || '-' %></td>
          <td class="small-text"><%= c.last_received || '-' %></td>
          <td class="small-text"><%= (c.registered_at || '').substring(0,10) || '-' %></td>
          <td>
            <a href="/admin/candidates/<%= c.line_user_id %>" class="btn btn-sm">詳細</a>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</main>

<script>
function applyFilters() {
  const needsReplyOnly = document.getElementById('filterNeedsReply').checked;
  const hideBlocked = document.getElementById('filterHideBlocked').checked;
  const statusFilter = document.getElementById('filterStatus').value;

  document.querySelectorAll('#candidatesTable tbody tr[data-needs-reply]').forEach(row => {
    let show = true;
    if (needsReplyOnly && row.dataset.needsReply !== '1') show = false;
    if (hideBlocked && row.dataset.blocked === '1') show = false;
    if (statusFilter && row.dataset.status !== statusFilter) show = false;
    row.style.display = show ? '' : 'none';
  });
}
// 初期表示時にブロック済みを非表示
applyFilters();
</script>
</body>
</html>
