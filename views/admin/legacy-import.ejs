<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>CSVインポート - 過去採用者 - COLOR KITCHEN 採用管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner">
    <h1><a href="/admin" style="color:white;text-decoration:none">COLOR KITCHEN 採用管理</a></h1>
    <button class="hamburger" id="hamburger" aria-label="メニュー" onclick="toggleMenu()">
      <span></span><span></span><span></span>
    </button>
    <nav class="header-nav" id="headerNav">
      <a href="/admin" class="nav-link">応募者管理</a>
      <a href="/admin/templates" class="nav-link">テンプレート</a>
      <a href="/admin/auto-replies" class="nav-link">自動返信</a>
      <a href="/admin/legacy-candidates" class="nav-link">過去採用者</a>
      <a href="/admin/settings" class="nav-link">管理者設定</a>
      <a href="/admin/security/2fa" class="nav-link">セキュリティ</a>
      <a href="/admin/settings/line" class="nav-link">LINE設定</a>
      <a href="/admin/logout" class="logout-link">ログアウト</a>
    </nav>
  </div>
</header>
<main>
  <a href="/admin/legacy-candidates" class="back-link">← 過去採用者一覧に戻る</a>

  <div class="page-header">
    <h2>CSVインポート</h2>
  </div>

  <% if (msg) { %>
  <div class="alert alert-success"><%= msg %></div>
  <% } %>
  <% if (error) { %>
  <div class="alert alert-error"><%= error %></div>
  <% } %>

  <!-- ファイルアップロード -->
  <div class="card">
    <h3>CSVファイルを選択</h3>
    <p style="font-size:0.82rem;color:#888;margin-bottom:1rem">
      UTF-8またはShift_JISのCSVファイルに対応しています。<br>
      使用できる日本語ヘッダー：氏名、フリガナ、電話番号、メール、最寄駅、希望店舗、雇用形態、応募日、採用結果、採用媒体、採用費、担当者、メモ、在籍状況、備考
    </p>
    <form action="/admin/legacy-candidates/import/preview" method="POST" enctype="multipart/form-data">
      <div class="form-group">
        <label>CSVファイル</label>
        <input type="file" name="csvfile" accept=".csv" required style="padding:0.4rem">
      </div>
      <button type="submit" class="btn-primary">プレビューを確認する</button>
    </form>
  </div>

  <% if (preview && preview.length > 0) { %>
  <!-- プレビュー表示 -->
  <div class="card">
    <h3>インポートプレビュー</h3>
    <div class="alert alert-success" style="margin-bottom:1rem">
      合計 <strong><%= totalRows %>件</strong> のデータが検出されました（プレビューは最初の10件を表示）
    </div>
    <div class="table-wrap" style="margin-bottom:1.25rem">
      <table style="font-size:0.78rem">
        <thead>
          <tr>
            <% columns.forEach(col => { %>
            <th><%= col %></th>
            <% }) %>
          </tr>
        </thead>
        <tbody>
          <% preview.forEach(row => { %>
          <tr>
            <% columns.forEach(col => { %>
            <td style="white-space:nowrap;max-width:120px;overflow:hidden;text-overflow:ellipsis" title="<%= row[col] || '' %>"><%= row[col] || '' %></td>
            <% }) %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <form action="/admin/legacy-candidates/import/execute" method="POST">
      <div style="display:flex;gap:0.75rem;align-items:center">
        <button type="submit" class="btn-primary" onclick="return confirm('<%= totalRows %>件のデータをインポートしますか？')">
          <%= totalRows %>件をインポートする
        </button>
        <a href="/admin/legacy-candidates/import" class="btn-secondary" style="text-decoration:none">キャンセル</a>
      </div>
    </form>
  </div>
  <% } %>

</main>
<script>
function toggleMenu() {
  document.getElementById('headerNav').classList.toggle('open');
}
</script>
</body>
</html>
