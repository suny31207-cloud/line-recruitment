<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= c.name || c.display_name || c.line_user_id %> - COLOR KITCHEN 採用管理</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
<header>
  <div class="header-inner">
    <h1>COLOR KITCHEN 採用管理</h1>
    <nav class="header-nav">
      <a href="/admin/templates" class="nav-link">テンプレート</a>
      <a href="/admin/auto-replies" class="nav-link">自動返信</a>
      <a href="/admin/settings" class="nav-link">設定</a>
      <a href="/admin/logout" class="logout-link">ログアウト</a>
    </nav>
  </div>
</header>
<main>
  <a href="/admin" class="back-link">← 応募者一覧に戻る</a>

  <% if (msg) { %>
  <div class="alert alert-success"><%= msg %></div>
  <% } %>

  <div class="detail-title">
    <div class="detail-title-row">
      <h2>
        <%= c.name || c.display_name || '(名前未登録)' %>
        <% if (c.needs_reply === '要返信') { %>
          <span class="badge-needs-reply" style="font-size:0.8rem;margin-left:0.5rem">要返信</span>
        <% } else if (c.needs_reply === '対応済み') { %>
          <span class="badge-replied" style="font-size:0.8rem;margin-left:0.5rem">対応済み</span>
        <% } %>
      </h2>
      <span class="status-badge status-<%= (c.status || '').replace(/\s/g,'_') %>"><%= c.status || '-' %></span>
    </div>
    <div class="sub-text">LINE ID: <%= c.line_user_id %></div>
  </div>

  <!-- アクションボタン -->
  <div class="action-buttons">
    <% if (lineOfficialChatUrl) { %>
    <a href="<%= lineOfficialChatUrl %>" target="_blank" rel="noopener noreferrer" class="btn-line-open">
      公式LINEを開く
    </a>
    <% } %>
    <% if (c.needs_reply === '要返信') { %>
    <form action="/admin/candidates/<%= c.line_user_id %>/mark-replied" method="POST" style="display:inline">
      <button type="submit" class="btn-mark-replied" onclick="return confirm('要返信を対応済みにしますか？')">
        要返信を対応済みにする
      </button>
    </form>
    <% } %>
  </div>

  <!-- 2カラムレイアウト -->
  <div class="detail-columns">

    <!-- 左カラム：応募者情報 -->
    <div class="detail-col-left">

      <form action="/admin/candidates/<%= c.line_user_id %>" method="POST">

        <!-- 基本情報 -->
        <div class="card">
          <h3>基本情報</h3>
          <div class="grid-2">
            <div class="form-group">
              <label>氏名</label>
              <input type="text" name="name" value="<%= c.name || '' %>">
            </div>
            <div class="form-group">
              <label>ふりがな</label>
              <input type="text" name="kana" value="<%= c.kana || '' %>">
            </div>
            <div class="form-group">
              <label>携帯番号</label>
              <input type="tel" name="phone" value="<%= c.phone || '' %>">
            </div>
            <div class="form-group">
              <label>年齢</label>
              <input type="number" name="age" value="<%= c.age || '' %>" min="15" max="80">
            </div>
            <div class="form-group">
              <label>性別</label>
              <select name="gender">
                <option value="">選択なし</option>
                <% ['男性','女性','その他','回答しない'].forEach(v => { %>
                <option value="<%= v %>" <%= c.gender===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>最寄駅</label>
              <input type="text" name="station" value="<%= c.station || '' %>">
            </div>
          </div>
        </div>

        <!-- アンケート情報 -->
        <div class="card">
          <h3>アンケート情報</h3>
          <div class="grid-2">
            <div class="form-group">
              <label>希望店舗</label>
              <select name="store">
                <option value="">選択なし</option>
                <% stores.forEach(v => { %>
                <option value="<%= v %>" <%= c.store===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>希望雇用形態</label>
              <select name="employment">
                <option value="">選択なし</option>
                <% ['正社員','パート・アルバイト'].forEach(v => { %>
                <option value="<%= v %>" <%= c.employment===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>美容師経験</label>
              <select name="experience">
                <option value="">選択なし</option>
                <% ['あり（5年以上）','あり（3〜5年）','あり（1〜3年）','あり（1年未満）','なし（見習い）','なし'].forEach(v => { %>
                <option value="<%= v %>" <%= c.experience===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>サイドシャンプー</label>
              <select name="side_shampoo">
                <option value="">選択なし</option>
                <% ['あり','なし'].forEach(v => { %>
                <option value="<%= v %>" <%= c.side_shampoo===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>希望内容</label>
              <select name="preference">
                <option value="">選択なし</option>
                <% ['見学希望','面接希望'].forEach(v => { %>
                <option value="<%= v %>" <%= c.preference===v?'selected':'' %>><%= v %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>勤務開始希望日</label>
              <input type="text" name="start_date" value="<%= c.start_date || '' %>" placeholder="例: 2026年7月〜">
            </div>
          </div>
        </div>

        <!-- 候補日時承認 -->
        <% if (candidateDates && candidateDates.length > 0) { %>
        <div class="card" style="border-left: 4px solid #2d6a4f;">
          <h3>候補日時の承認</h3>
          <p style="font-size:0.82rem;color:#666;margin-bottom:0.75rem">応募者が希望した日時を承認すると、自動でLINE通知が送信されます。</p>
          <% candidateDates.forEach(d => { %>
          <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:0.6rem;flex-wrap:wrap">
            <span style="font-size:0.85rem;font-weight:600;min-width:60px"><%= d.label %></span>
            <span style="font-size:0.9rem;flex:1"><%= d.value %></span>
            <div style="display:flex;gap:0.4rem">
              <form action="/admin/candidates/<%= c.line_user_id %>/confirm-date" method="POST" style="display:inline">
                <input type="hidden" name="confirmed_date" value="<%= d.value %>">
                <input type="hidden" name="date_type" value="visit">
                <button type="submit" class="btn-approve" onclick="return confirm('<%= d.value %> で見学日程を確定しますか？')">見学確定</button>
              </form>
              <form action="/admin/candidates/<%= c.line_user_id %>/confirm-date" method="POST" style="display:inline">
                <input type="hidden" name="confirmed_date" value="<%= d.value %>">
                <input type="hidden" name="date_type" value="interview">
                <button type="submit" class="btn-approve" style="background:#495057" onclick="return confirm('<%= d.value %> で面接日程を確定しますか？')">面接確定</button>
              </form>
            </div>
          </div>
          <% }) %>
        </div>
        <% } %>

        <!-- 対応管理 -->
        <div class="card">
          <h3>対応管理</h3>
          <div class="grid-2">
            <div class="form-group">
              <label>ステータス</label>
              <select name="status">
                <% statuses.forEach(s => { %>
                <option value="<%= s %>" <%= c.status===s?'selected':'' %>><%= s %></option>
                <% }) %>
              </select>
            </div>
            <div class="form-group">
              <label>見学日</label>
              <input type="text" name="visit_date" value="<%= c.visit_date || '' %>" placeholder="例: 2026/06/01 14:00">
            </div>
            <div class="form-group">
              <label>面接日</label>
              <input type="text" name="interview_date" value="<%= c.interview_date || '' %>" placeholder="例: 2026/06/05 10:00">
            </div>
            <div class="form-group">
              <label>登録日時</label>
              <input type="text" value="<%= c.registered_at || '-' %>" readonly class="readonly-field">
            </div>
          </div>
          <div class="form-group">
            <label>備考</label>
            <textarea name="note" rows="3"><%= c.note || '' %></textarea>
          </div>
        </div>

        <!-- 見学後アンケート -->
        <div class="card">
          <h3>見学後アンケート</h3>
          <% if (visitSurvey) { %>
          <div class="visit-survey-grid">
            <div class="vs-item"><span class="vs-label">見学日</span><span class="vs-value"><%= visitSurvey.visit_date || '-' %></span></div>
            <div class="vs-item"><span class="vs-label">見学店舗</span><span class="vs-value"><%= visitSurvey.visit_store || '-' %></span></div>
            <div class="vs-item"><span class="vs-label">入社意欲</span><span class="vs-value"><%= visitSurvey.motivation || '-' %></span></div>
            <div class="vs-item"><span class="vs-label">面接希望</span><span class="vs-value"><%= visitSurvey.wants_interview || '-' %></span></div>
          </div>
          <% if (visitSurvey.impression) { %>
          <div class="form-group" style="margin-top:0.75rem">
            <label>見学後の印象</label>
            <div class="inquiry-content"><%= visitSurvey.impression %></div>
          </div>
          <% } %>
          <% if (visitSurvey.concerns) { %>
          <div class="form-group">
            <label>気になった点</label>
            <div class="inquiry-content"><%= visitSurvey.concerns %></div>
          </div>
          <% } %>
          <div class="sub-text" style="margin-top:0.5rem">回答日時: <%= visitSurvey.submitted_at || '-' %></div>
          <% } else { %>
          <p class="text-muted" style="font-size:0.88rem">未回答</p>
          <a href="/survey-visit/<%= c.line_user_id %>" target="_blank" class="btn btn-sm" style="margin-top:0.5rem">アンケートURLを確認</a>
          <% } %>
        </div>

        <!-- 回答結果 -->
        <div class="card">
          <h3>回答結果</h3>
          <div class="grid-2">
            <div class="form-group">
              <label>回答結果</label>
              <input type="text" value="<%= c.answer || '-' %>" readonly class="readonly-field">
            </div>
            <div class="form-group">
              <label>回答日時</label>
              <input type="text" value="<%= c.answer_date || '-' %>" readonly class="readonly-field">
            </div>
          </div>
        </div>

        <button type="submit" class="btn-primary btn-block">保存する</button>
      </form>
    </div>

    <!-- 右カラム：トーク履歴 + LINE送信 -->
    <div class="detail-col-right">

      <!-- 要返信・問い合わせ情報 -->
      <% if (c.needs_reply === '要返信') { %>
      <div class="card needs-reply-card">
        <h3>未対応の問い合わせ</h3>
        <div class="grid-2">
          <div class="form-group">
            <label>問い合わせ日時</label>
            <input type="text" value="<%= c.latest_inquiry_date || '-' %>" readonly class="readonly-field">
          </div>
          <div class="form-group">
            <label>最終受信日時</label>
            <input type="text" value="<%= c.last_received || '-' %>" readonly class="readonly-field">
          </div>
        </div>
        <% if (c.latest_inquiry) { %>
        <div class="form-group">
          <label>最新問い合わせ内容</label>
          <div class="inquiry-content"><%= c.latest_inquiry %></div>
        </div>
        <% } %>
      </div>
      <% } %>

      <!-- トーク履歴 -->
      <div class="card">
        <h3>トーク履歴 <span class="count-badge"><%= messages.length %>件</span></h3>
        <div class="chat-container" id="chatContainer">
          <% if (messages.length === 0) { %>
          <p class="text-muted text-center" style="padding:2rem 0">メッセージはありません</p>
          <% } %>
          <% messages.forEach(m => { %>
          <div class="chat-message chat-<%= m.direction %>">
            <div class="chat-bubble"><%= m.content %></div>
            <div class="chat-meta">
              <span class="chat-time"><%= m.sent_at || '' %></span>
              <% if (m.direction !== 'in') { %>
              <span class="chat-sender"><%= m.sent_by || 'bot' %></span>
              <% } %>
            </div>
          </div>
          <% }) %>
        </div>
      </div>

      <!-- LINE送信 -->
      <div class="card">
        <h3>LINE送信</h3>
        <% if (c.needs_reply === '要返信') { %>
        <p class="warn-text">この応募者は要返信です。送信すると自動で対応済みになります。</p>
        <% } %>
        <form action="/admin/candidates/<%= c.line_user_id %>/send" method="POST">
          <div class="form-group">
            <label>送信タイプ</label>
            <select name="messageType" id="msgType" onchange="toggleSendType()">
              <option value="custom">カスタムメッセージ</option>
              <option value="template">テンプレートを使用</option>
              <option value="interview_followup">入社/辞退ボタン（面接後）</option>
              <option value="visit_invite">見学誘導</option>
              <option value="visit_survey">見学後アンケート依頼</option>
              <option value="rejection">不採用通知</option>
            </select>
          </div>

          <div id="templateSelectGroup" style="display:none" class="form-group">
            <label>テンプレートを選択</label>
            <select name="template_id" id="templateSelect" onchange="fillTemplate()">
              <option value="">選択してください</option>
              <% templates.forEach(t => { %>
              <option value="<%= t.id %>" data-content="<%= encodeURIComponent(t.content) %>">
                <%= t.name %><% if (t.purpose) { %> (<%= t.purpose %>)<% } %>
              </option>
              <% }) %>
            </select>
          </div>

          <div id="customTextGroup" class="form-group">
            <label>メッセージ内容</label>
            <textarea name="customText" id="customText" rows="5" placeholder="送信するメッセージを入力してください"></textarea>
          </div>

          <div id="btnOnlyMsg" style="display:none" class="form-note">
            送信ボタンを押すと自動的にLINEボタンメッセージを送信します。
          </div>

          <button type="submit" class="btn-secondary btn-block">LINEを送信する</button>
        </form>

        <% if (lineOfficialChatUrl) { %>
        <div style="margin-top:1rem">
          <a href="<%= lineOfficialChatUrl %>" target="_blank" rel="noopener noreferrer" class="btn-line-open btn-block">
            公式LINEを開く
          </a>
        </div>
        <% } %>
      </div>

    </div>
  </div>
</main>

<script>
function toggleSendType() {
  const type = document.getElementById('msgType').value;
  const templateGroup = document.getElementById('templateSelectGroup');
  const customGroup = document.getElementById('customTextGroup');
  const btnMsg = document.getElementById('btnOnlyMsg');

  const isBtn = ['interview_followup', 'visit_invite', 'visit_survey', 'rejection'].includes(type);
  const isTemplate = type === 'template';
  const isCustom = type === 'custom';

  templateGroup.style.display = isTemplate ? 'block' : 'none';
  customGroup.style.display = (isCustom || isTemplate) ? 'block' : 'none';
  btnMsg.style.display = isBtn ? 'block' : 'none';

  if (isCustom) {
    document.getElementById('customText').value = '';
  }
}

function fillTemplate() {
  const sel = document.getElementById('templateSelect');
  const opt = sel.options[sel.selectedIndex];
  if (opt && opt.dataset.content) {
    document.getElementById('customText').value = decodeURIComponent(opt.dataset.content);
  }
}

// チャットを最下部にスクロール
window.addEventListener('load', function() {
  const chat = document.getElementById('chatContainer');
  if (chat) chat.scrollTop = chat.scrollHeight;
});
</script>
</body>
</html>
