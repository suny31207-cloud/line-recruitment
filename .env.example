# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Sheets API（サービスアカウント）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# GoogleスプレッドシートID（URLの /d/〇〇〇/ の部分）
GOOGLE_SHEET_ID=

# 本番サーバーの公開URL（アンケートリンク生成に使用）
APP_URL=https://line-recruitment.onrender.com

# LIFF アプリID（任意 - 設定するとLINE内ブラウザで直接アンケートが開く）
LIFF_ID=

# ポート（Render/Railwayでは自動設定）
PORT=3000
