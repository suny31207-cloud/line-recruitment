# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google Sheets API（サービスアカウント）- バックアップ用オプション
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# GoogleスプレッドシートID（URLの /d/〇〇〇/ の部分）
GOOGLE_SHEET_ID=

# 本番サーバーの公開URL（アンケートリンク生成に使用）
APP_URL=https://line-recruitment.onrender.com

# LIFF アプリID（任意 - 設定するとLINE内ブラウザで直接アンケートが開く）
LIFF_ID=

# 管理画面ログイン
ADMIN_ID=admin
ADMIN_PASSWORD=
SESSION_SECRET=

# LINE公式アカウントチャット管理画面URL（管理画面の「公式LINEを開く」ボタンで使用）
LINE_OFFICIAL_CHAT_URL=

# メール通知先（カンマ区切りで複数指定可）
NOTIFY_EMAIL_TO=

# Gmail（メール通知用）
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ポート（Render/Railwayでは自動設定）
PORT=3000

# SQLite DBファイルパス（デフォルト: ./data/recruitment.db）
DB_PATH=./data/recruitment.db

# LINE公式アカウント情報（参考用）
LINE_OFFICIAL_ACCOUNT_NAME=
LINE_OFFICIAL_ACCOUNT_ID=
LINE_ADD_FRIEND_URL=
LINE_QR_CODE_URL=
LINE_WEBHOOK_URL=
LIFF_URL=
